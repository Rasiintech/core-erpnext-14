 "html": "<div class=\"po-container\">\n    <table class=\"header-table\">\n        <tr>\n            <td width=\"50%\">\n                {% if letter_head %}\n                    {{ letter_head }}\n                {% else %}\n                    <h2 style=\"color: #333;\">{{ \"Shaafi Hospital\" }}</h2>\n                {% endif %}\n            </td>\n          \n        </tr>\n        <tr>\n            \n          <td width=\"50%\" style=\"text-align: left;\">\n                <h1 style=\"margin: 0; color: #555; text-transform: uppercase;\">Purchase Order</h1>\n                <p style=\"margin: 5px 0;\"><strong>No:</strong> {{ doc.name or \"\"}}</p>\n                <p style=\"margin: 5px 0;\"><strong>Date:</strong> {{ doc.transaction_date or \"\"}}</p>\n            </td>\n        </tr>\n    </table>\n\n    <hr style=\"border: 0.5px solid #eee; margin: 20px 0;\">\n\n    <table class=\"address-table\">\n        <tr>\n            <td width=\"50%\">\n                <p class=\"section-title\">Supplier</p>\n                <div class=\"address-box\">\n                    <strong>{{ doc.supplier or \"\"}}</strong><br>\n                </div>\n            </td>\n        </tr>\n    </table>\n\n    <table class=\"items-table\">\n        <thead>\n            <tr>\n                <th style=\"width: 5%;\">#</th>\n                <th style=\"width: 45%;\">Description</th>\n                <th style=\"width: 15%; text-align: right;\">Qty</th>\n                <th style=\"width: 15%; text-align: right;\">Rate</th>\n                <th style=\"width: 20%; text-align: right;\">Amount</th>\n            </tr>\n        </thead>\n        <tbody>\n            {% for item in doc.items %}\n            <tr>\n                <td>{{ item.idx }}</td>\n                <td>\n                    <strong>{{ item.item_code }}</strong><br>\n                    <small style=\"color: #666;\">{{ item.description }}</small>\n                </td>\n                <td style=\"text-align: right;\">{{ item.qty }} {{ item.uom }}</td>\n                <td style=\"text-align: right;\">{{ item.rate }}</td>\n                <td style=\"text-align: right;\">{{ item.amount }}</td>\n            </tr>\n            {% endfor %}\n        </tbody>\n    </table>\n\n    <div style=\"display: flex; justify-content: flex-end; margin-top: 20px;\">\n        <table class=\"totals-table\">\n            <tr>\n                <td>Total Quantity</td>\n                <td class=\"text-right\">{{ doc.grand_total or \"\" }}</td>\n            </tr>\n            <tr>\n                <td>Net Total</td>\n                <td class=\"text-right\">{{ doc.grand_total or \"\"  }}</td>\n            </tr>\n        </table>\n    </div>\n\n    <div style=\"margin-top: 20px; display: flex; justify-content: space-between;\">\n        <div>\n        <p class=\"section-title\">Prepared By</p>\n        <p style=\"font-size: 10pt; color: #555; font-weight: bold;\">Name:</p>\n        <p style=\"font-size: 10pt; color: #555; font-weight: bold;\">Signature:</p>\n        </div>\n    </div>\n    <div style=\"border: 1px solid black\"></div>\n    <div style=\"margin-top: 10px; display: flex; flex-direction: column; justify-content: space-between;\">\n        <div>\n        <p class=\"section-title\"> Reviewed By</p>\n        <p style=\"font-size: 10pt; color: #555; font-weight: bold;\">Name:</p>\n        <p style=\"font-size: 10pt; color: #555; font-weight: bold;\">Signature:</p>\n        </div>\n    <div style=\"border: 1px solid black\"></div>\n        <div>\n        <p class=\"section-title\">Reviewed By</p>\n        <p style=\"font-size: 10pt; color: #555; font-weight: bold;\">Name:</p>\n        <p style=\"font-size: 10pt; color: #555; font-weight: bold;\">Signature:</p>\n        </div>\n    </div>\n    <div style=\"border: 1px solid black\"></div>\n    <div style=\"margin-top: 10px; display: flex; flex-direction: column; justify-content: space-between;\">\n        <div>\n        <p class=\"section-title\"> Approved By</p>\n        <p style=\"font-size: 10pt; color: #555; font-weight: bold;\">Name:</p>\n        <p style=\"font-size: 10pt; color: #555; font-weight: bold;\">Signature:</p>\n        </div>\n    <div style=\"border: 1px solid black\"></div>\n        <div>\n        <p class=\"section-title\">Approved By</p>\n        <p style=\"font-size: 10pt; color: #555; font-weight: bold;\">Name:</p>\n        <p style=\"font-size: 10pt; color: #555; font-weight: bold;\">Signature:</p>\n        </div>\n    </div>\n</div>\n\n<style>\n    .po-container {\n        font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;\n        color: #333;\n        font-size: 11pt;\n        padding: 10px;\n    }\n    .header-table, .address-table, .items-table {\n        width: 100%;\n        border-collapse: collapse;\n    }\n    .section-title {\n        text-transform: uppercase;\n        font-weight: bold;\n        font-size: 9pt;\n        color: #888;\n        margin-bottom: 5px;\n    }\n    .address-box {\n        font-size: 10pt;\n        line-height: 1.4;\n    }\n    .items-table {\n        margin-top: 30px;\n    }\n    .items-table th {\n        background-color: #f8f9fa;\n        border-bottom: 2px solid #ddd;\n        padding: 10px 5px;\n        text-align: left;\n        font-size: 10pt;\n    }\n    .items-table td {\n        border-bottom: 1px solid #eee;\n        padding: 10px 5px;\n        vertical-align: top;\n    }\n    .totals-table {\n        width: 300px;\n        border-collapse: collapse;\n    }\n    .totals-table td {\n        padding: 8px 5px;\n        border-bottom: 1px solid #f1f1f1;\n    }\n    .grand-total {\n        background-color: #f8f9fa;\n    }\n    .text-right {\n        text-align: right;\n    }\n</style>",
